<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- libv2ray.aar declares minSdk 24; override so the app keeps minSdk 21 -->
    <uses-sdk tools:overrideLibrary="go.libv2ray.gojni" />

    <!-- Required for foreground service (keeps xray-core alive in background) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Internet access (inherited from app, but declared explicitly for clarity) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for auto-reconnect: monitoring network changes -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required for VpnBootReceiver to restore proxy after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application>
        <service
            android:name="com.telegram.vpncore.ProxyForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <receiver
            android:name="com.telegram.vpncore.VpnBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
